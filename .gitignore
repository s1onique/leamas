# Local/generated review artifacts
build/

# Go build/test artifacts
bin/
*.test
coverage.out

# Release artifacts
dist/

# Factory artifacts (except committed baseline)
.factory/*
!.factory/dupcode-baseline.json
!.factory/long-tests-baseline.json

# Adversarial test helper: keep the source, ignore the local build artifact
# (compiled binary is referenced by adversarial_harness_executor.go via
# `internal/execution/testdata/testhelper/main`; it must NOT be committed).
internal/execution/testdata/testhelper/main
!internal/execution/testdata/testhelper/main.go
/testdata/

# Canonical doctrine compiler golden fixtures are source-controlled
# and must be visible to `git add` despite the broad testdata/ rule above.
!internal/factory/doctrinecompiler/testdata/
!internal/factory/doctrinecompiler/testdata/**
